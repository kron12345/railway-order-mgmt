{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "codex review --commit HEAD 2>&1 | tail -50",
            "timeout": 120,
            "statusMessage": "Codex Code Review laeuft..."
          }
        ]
      }
    ]
  }
}
