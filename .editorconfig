# EditorConfig - consistent coding styles across editors
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.java]
indent_size = 4

[*.{yaml,yml}]
indent_size = 2

[*.{json,xml}]
indent_size = 2

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.properties]
charset = utf-8

[*.sql]
indent_size = 4

[*.{css,scss}]
indent_size = 2

[*.{html,js,ts}]
indent_size = 2

[Makefile]
indent_style = tab

[pom.xml]
indent_size = 4
