{
  "realm": "railway",
  "enabled": true,
  "displayName": "Railway Order Management",
  "defaultLocale": "de",
  "internationalizationEnabled": true,
  "supportedLocales": [
    "de",
    "en",
    "it",
    "fr"
  ],
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Full system access \u2014 manage users, settings, all data"
      },
      {
        "name": "dispatcher",
        "description": "Manage orders, routes, and railcar assignments"
      },
      {
        "name": "customer-manager",
        "description": "Manage customer data and contracts"
      },
      {
        "name": "viewer",
        "description": "Read-only access to all data"
      }
    ]
  },
  "clients": [
    {
      "clientId": "order-mgmt",
      "name": "Railway Order Management",
      "enabled": true,
      "publicClient": false,
      "secret": "dev-secret-change-in-production",
      "redirectUris": [
        "http://localhost:8080/*",
        "https://railway-order-mgmt.hub.animeland.de/*",
        "http://localhost:8085/*"
      ],
      "webOrigins": [
        "http://localhost:8080",
        "https://railway-order-mgmt.hub.animeland.de"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect",
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ]
    }
  ],
  "users": [
    {
      "username": "sebastian",
      "email": "sebastian@railway.local",
      "firstName": "Sebastian",
      "lastName": "Admin",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "sebastian",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin",
        "dispatcher",
        "customer-manager"
      ]
    },
    {
      "username": "dispatcher",
      "email": "dispatcher@railway.local",
      "firstName": "Test",
      "lastName": "Dispatcher",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "dispatcher",
          "temporary": false
        }
      ],
      "realmRoles": [
        "dispatcher"
      ]
    },
    {
      "username": "viewer",
      "email": "viewer@railway.local",
      "firstName": "Test",
      "lastName": "Viewer",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "viewer",
          "temporary": false
        }
      ],
      "realmRoles": [
        "viewer"
      ]
    }
  ]
}