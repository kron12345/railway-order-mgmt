# ===========================================
# Railway Order Management - Environment
# ===========================================
# Copy this file to .env and adjust values.
# NEVER commit the .env file!

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ordermgmt
DB_USER=ordermgmt
DB_PASSWORD=ordermgmt

# --- Keycloak ---
KEYCLOAK_ISSUER_URI=http://localhost:8180/realms/railway
KEYCLOAK_CLIENT_ID=order-mgmt
KEYCLOAK_CLIENT_SECRET=dev-secret-change-in-production

# --- Application ---
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev
